# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Dashboard > Settings > Database > Connection string (URI) — usado só localmente/scripts
DATABASE_URL=postgresql://postgres:<senha>@db.<ref>.supabase.co:5432/postgres

# AI / Speech
OPENAI_API_KEY=sk-...          # Whisper STT
ELEVENLABS_API_KEY=...         # TTS
ANTHROPIC_API_KEY=sk-ant-...   # Evaluation via Claude

# Payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email
RESEND_API_KEY=re_...

# Observability
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=https://...@sentry.io/...
